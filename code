  .case-list-name { font-size: 0.76rem; color: #ddd; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .case-list-date { font-size: 0.68rem; color: #888; }
  .case-no-results { padding: 16px 12px; font-size: 0.75rem; color: #666; text-align: center; font-style: italic; }

