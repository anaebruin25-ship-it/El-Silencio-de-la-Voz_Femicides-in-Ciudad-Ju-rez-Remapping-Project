const clusters = L.markerClusterGroup({
  maxClusterRadius: 40, zoomToBoundsOnClick: false,
  spiderfyOnMaxZoom: false, showCoverageOnHover: false,
  iconCreateFunction: function(cluster) {
    const count = cluster.getChildCount();
    return L.divIcon({ html: '<div class="hex-cluster">' + count + '</div>', className: '', iconSize: [40, 40] });
  }
});

function buildCaseHtml(d) {
  let html = '<div class="popup-name">' + d.name + '</div>';
  html += '<div class="popup-case">Case #' + d.n + '</div>';
  html += '<div class="popup-row"><span class="popup-label">Age:</span><span class="popup-val">' + d.age + '</span></div>';
  html += '<div class="popup-row"><span class="popup-label">Found:</span><span class="popup-val">' + d.date + '</span></div>';
  if (d.place) html += '<div class="popup-row"><span class="popup-label">Location:</span><span class="popup-val">' + d.place + '</span></div>';
  html += '<div class="popup-row"><span class="popup-label">Cause:</span><span class="popup-val">' + d.cause + '</span></div>';
  if (d.attacker) html += '<div class="popup-attacker">⚠ Attacker: ' + d.attacker + '</div>';
  if (d.details) html += '<div class="popup-attacker" style="color:#ffddaa">📌 ' + d.details + '</div>';
  return html;
}

let selectedMarker = null;
const markersByN = {};

function setMarkerOrange(marker, on) {
  const el = marker.getElement && marker.getElement();
  if (!el) return;
  const dot = el.querySelector('.num-marker');
  if (dot) dot.classList.toggle('selected', on);
}
function selectMarker(marker) {
  if (selectedMarker && selectedMarker !== marker) setMarkerOrange(selectedMarker, false);
  selectedMarker = marker;
  setMarkerOrange(marker, true);
}
function clearSelection() {
  if (selectedMarker) { setMarkerOrange(selectedMarker, false); selectedMarker = null; }
}

// Jump to a case by number from the list panel
function jumpToCase(n) {
  const marker = markersByN[n];
  if (!marker) return;
  clusters.zoomToShowLayer(marker, function() {
    marker.openPopup();
    map.setView(marker.getLatLng(), Math.max(map.getZoom(), 16), { animate: true });
  });
}

points.forEach(p => {
  const icon = L.divIcon({
    html: '<div class="num-marker">' + p.n + '</div>',
    className: '', iconSize: [24, 24], iconAnchor: [12, 12], popupAnchor: [0, -14]
  });
  const marker = L.marker([p.lat, p.lng], { icon, caseN: p.n, caseData: p });
  marker.bindPopup(buildCaseHtml(p), { maxWidth: 300 });
  marker.on('popupopen', () => {
    selectMarker(marker);
    const el = marker.getPopup().getElement();
    if (el) el.classList.add('popup-selected');
  });
  marker.on('popupclose', () => { if (selectedMarker === marker) clearSelection(); });
  clusters.addLayer(marker);
  markersByN[p.n] = marker;
});
map.addLayer(clusters);

// Build case list
function buildCaseList(filter) {
  const container = document.getElementById('case-list');
  const q = (filter || '').toLowerCase().trim();
  const filtered = points.filter(p => {
    if (!q) return true;
    const num = String(p.n);
    return num === q || p.name.toLowerCase().includes(q) || num.startsWith(q);
  });
  if (filtered.length === 0) {
    container.innerHTML = '<div class="case-no-results">No cases found</div>';
    return;
  }
  container.innerHTML = filtered.map(p =>
    `<div class="case-list-item" onclick="jumpToCase(${p.n})">
      <div class="case-list-num">${p.n}</div>
      <div class="case-list-info">
        <div class="case-list-name">${p.name}</div>
        <div class="case-list-date">${p.date}</div>
      </div>
    </div>`
  ).join('');
}
function filterCases(val) { buildCaseList(val); }
buildCaseList('');

// Cluster click
clusters.on('clusterclick', function(a) {
  const childMarkers = a.layer.getAllChildMarkers();
  const center = a.layer.getLatLng();
  function listHtml() {
    let html = '<div class="popup-name">' + childMarkers.length + ' cases at this location</div>';
    html += '<div class="cluster-list">';
    childMarkers.slice().sort((m1, m2) => m1.options.caseN - m2.options.caseN).forEach(m => {
      const d = m.options.caseData;
      html += '<div class="cluster-item" data-case="' + m.options.caseN + '">';
      html += '<span class="cluster-item-num' + (m === selectedMarker ? ' selected' : '') + '">' + d.n + '</span>';
      html += '<span class="cluster-item-name">' + d.name + '</span></div>';
    });
    html += '</div><div class="cluster-hint">Click a name for full case details</div>';
    return html;
  }
  function caseHtmlWithBack(caseN) {
    const marker = childMarkers.find(m => m.options.caseN === caseN);
    return buildCaseHtml(marker.options.caseData) +
      '<div class="cluster-back" data-action="back">&larr; Back to list of ' + childMarkers.length + ' cases</div>';
  }
  function wireList(container) {
    container.classList.remove('popup-selected');
    L.DomEvent.disableClickPropagation(container);
    container.querySelectorAll('.cluster-item').forEach(el => {
      el.addEventListener('click', e => {
        e.stopPropagation();
        const caseN = parseInt(el.getAttribute('data-case'), 10);
        const marker = childMarkers.find(m => m.options.caseN === caseN);
        popup.setContent(caseHtmlWithBack(caseN));
        const newEl = popup.getElement();
        wireBack(newEl);
        if (marker) {
          selectMarker(marker);
          newEl.classList.add('popup-selected');
          map.setView(marker.getLatLng(), Math.max(map.getZoom(), 16), { animate: true });
          map.once('moveend', () => setMarkerOrange(marker, true));
        }
      });
    });
  }
  function wireBack(container) {
    L.DomEvent.disableClickPropagation(container);
    const back = container.querySelector('.cluster-back');
    if (back) back.addEventListener('click', e => {
      e.stopPropagation();
      clearSelection();
      popup.setContent(listHtml());
      wireList(popup.getElement());
      map.setView(center, map.getZoom(), { animate: true });
      popup.setLatLng(center);
    });
  }
  const popup = L.popup({ maxWidth: 320, className: 'cluster-popup', autoPan: true })
    .setLatLng(center).setContent(listHtml()).openOn(map);
  popup.on('remove', () => clearSelection());
  setTimeout(() => wireList(popup.getElement()), 0);
});

function toggleCaseList() {
  const panel = document.getElementById('case-panel');
  const btn = document.getElementById('list-btn');
  const isOpen = panel.classList.contains('open');
  panel.classList.toggle('open');
  btn.classList.toggle('active');
  btn.textContent = isOpen ? '📋 Browse All Cases' : '✕ Close Case List';
  setTimeout(() => map.invalidateSize(), 360);
}

